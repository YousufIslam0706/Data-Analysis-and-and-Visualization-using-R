### Code by Yousuf Islam â€“ Enhanced for Plot + Table Output ###
##Upload main sheet( with replication)

# Load libraries
library(agricolae)
library(ggplot2)
library(dplyr)

# Load your dataset
data <- read.csv(file.choose())
head(data)
# Convert relevant columns to factor
data$Rep <- as.factor(data$Rep)
data$Date <- as.factor(data$Date)
data$Trt  <- as.factor(data$Trt)

# Remove rows with missing GY
data <- data[!is.na(data$GY), ]

# Split-plot ANOVA
model <- with(data, sp.plot(Rep, Date, Trt, GY))
gla <- model$gl.a
glb <- model$gl.b
Ea  <- model$Ea
Eb  <- model$Eb

# Create interaction variable
data$DateTrt <- interaction(data$Date, data$Trt, sep = " Ă— ")

# LSD test on interaction
out3 <- with(data, LSD.test(GY, DateTrt, glb, Eb, console = TRUE))

# Extract means and groups
means_df <- out3$means %>%
  mutate(DateTrt = rownames(.)) %>%
  left_join(
    out3$groups %>%
      mutate(DateTrt = rownames(.)) %>%
      select(DateTrt, groups),
    by = "DateTrt"
  )

# Fix SE column if missing
if (!"SE" %in% colnames(means_df)) {
  means_df$SE <- means_df$std  # Use 'std' from agricolae if 'SE' not present
}

# Assign significance stars based on group (this is illustrative)
means_df <- means_df %>%
  mutate(
    star = case_when(
      grepl("a", groups) ~ "***",
      grepl("b", groups) ~ "**",
      grepl("c", groups) ~ "*",
      TRUE ~ ""
    )
  )

# Create new label: Mean Â± SE with star
means_df <- means_df %>%
  mutate(label = paste0(round(GY, 2), " Â± ", round(SE, 2), " ", star))

# âś… Print formatted table
cat("đź”˘ Interaction Means Â± SE with Significance Stars:\n")
print(means_df[, c("DateTrt", "GY", "SE", "star", "label")], row.names = FALSE)

# Plot with ggplot2
ggplot(means_df, aes(x = DateTrt, y = GY)) +
  geom_bar(stat = "identity", aes(fill = DateTrt), width = 0.7, color = "black") +
  geom_errorbar(aes(ymin = GY - SE, ymax = GY + SE), width = 0.2) +
  geom_text(aes(label = star, y = GY + SE + 0.4), size = 6, color = "red") +  # significance stars
  labs(title = "",
       x = "Date Ă— Treatment",
       y = "Grain Yield (t/ha)") +
  theme_minimal(base_size = 14) +
  theme(
    axis.text.x = element_text(angle = 69, hjust = 1),
    plot.title = element_text(face = "bold", hjust = 0.5),
    legend.position = "none",
    panel.grid.major = element_blank(),  # Removes major grid lines
    panel.grid.minor = element_blank()   # Removes minor grid lines
  ) +
  scale_fill_brewer(palette = "Set2")
## save code
ggsave("interaction_plot_GY.png", device = "png", dpi = 1000, width = 10, height = 6, units = "in")


