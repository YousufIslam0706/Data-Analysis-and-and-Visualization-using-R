        #### part 2:  working with function  ####
# A function is a collection of statements combined to perform a specific task.


#### 1. Built-in Functions:

max(20, 77, 85, 12)
# 85

min(20, 77, 85, 12)
# 12

a <- c(-1, -3, 0, 5, 7, 8, 4, 6.3, 10)
plot(a, col='darkgreen')

#### 2. User-defined Functions:
# The basic syntax of an R function is:
# function_name <- function(arg_1, arg_2, ...) { Function body }

# R users can create user-defined functions. For example, you can create a function to convert miles to kilometers:

mile2km <- function(mile){
  km <- mile * 1.60934
  return(km)
}


mile2km(20)

# Define myMean function
myMean <- function(n){
  mean = sum(n)/length(n)
  return(mean)
}

# Call myMean function with argument
a <- c(2, 4, 6, 8, 10)
myMean(a)


# Call myMean function with another argument
myMean(c(10, 50, 20))

####  3. packages Function




             ####  Part 3: Working with packages  ###

#### Install packages
install.packages('ggplot2') # ggplot2 is An implementation of the grammar of graphics in R

# To install more than one packages together
install.packages(c("dplyr", "devtools", "foreign")) 

#### Call packages
# Before using any packages you have to load them using library function.
library(ggplot2) # to load functions from the package we have to call it.

#### Remove packages
# You can remove any packages that you do not need:
remove.packages("ggplot2") # for remove a package

#### Update packages
# Check old packages that need an update
old.packages()


# List of packages to install
